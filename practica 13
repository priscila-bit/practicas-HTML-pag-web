<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Práctica 13: Galería de Imágenes</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root { --primary: #10b981; }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #ecfdf5, #d1fae5);
            color: #333;
        }
        header {
            background: linear-gradient(to right, #10b981, #059669);
            color: white;
            text-align: center;
            padding: 2.5rem 0;
        }
        .container { max-width: 1200px; margin: 0 auto; padding: 20px; }
        h1 { font-size: 2.6rem; }
        h2 { color: var(--primary); margin: 30px 0 20px; text-align: center; }

        .galeria {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 18px;
            margin: 30px 0;
        }
        .galeria img {
            width: 100%;
            height: 240px;
            object-fit: cover;
            border-radius: 16px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            transition: all 0.4s;
        }
        .galeria img:hover { transform: scale(1.08); }

        .carrusel {
            position: relative;
            max-width: 850px;
            margin: 40px auto;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 15px 40px rgba(0,0,0,0.2);
        }
        .carrusel img {
            width: 100%;
            height: 520px;
            object-fit: cover;
            display: none;
        }
        .carrusel img.active { display: block; }

        .carrusel button {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(0,0,0,0.6);
            color: white;
            border: none;
            width: 55px;
            height: 55px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 1.8rem;
        }
        .carrusel .prev { left: 20px; }
        .carrusel .next { right: 20px; }

        footer {
            background: #1f2937;
            color: white;
            text-align: center;
            padding: 35px;
            margin-top: 60px;
        }
    </style>
</head>
<body>

    <header>
        <h1>Práctica 13: Galería de Imágenes</h1>
        <p>Vida Saludable</p>
    </header>

    <div class="container">

        <h2>🌿 Galería - Vida Saludable</h2>
        <div class="galeria">
            <img src="https://picsum.photos/id/1015/600/400" alt="Running en la montaña">
            <img src="https://picsum.photos/id/133/600/400" alt="Yoga al amanecer">
            <img src="https://picsum.photos/id/292/600/400" alt="Ensalada saludable">
            <img src="https://picsum.photos/id/1016/600/400" alt="Meditación">
            <img src="https://picsum.photos/id/870/600/400" alt="Ejercicio en parque">
            <img src="https://picsum.photos/id/431/600/400" alt="Frutas frescas">
        </div>

        <h2>🎠 Carrusel - Vida Saludable</h2>
        <div class="carrusel" id="carrusel">
            <img src="https://picsum.photos/id/1015/850/520" alt="Running" class="active">
            <img src="https://picsum.photos/id/133/850/520" alt="Yoga">
            <img src="https://picsum.photos/id/292/850/520" alt="Alimentación saludable">
            <img src="https://picsum.photos/id/1016/850/520" alt="Meditación">
            <img src="https://picsum.photos/id/870/850/520" alt="Deporte">
            
            <button class="prev" onclick="cambiarImagen(-1)">❮</button>
            <button class="next" onclick="cambiarImagen(1)">❯</button>
        </div>

    </div>

    <footer>
        <p><strong>Práctica 13: Galería de Imágenes Avanzada</strong></p>
        <p>Alumno: [Tu Nombre] | Fecha: [Fecha de entrega]</p>
    </footer>

    <script>
        let index = 0;
        const imagenes = document.querySelectorAll('#carrusel img');

        function mostrarImagen() {
            imagenes.forEach((img, i) => {
                img.classList.toggle('active', i === index);
            });
        }

        function cambiarImagen(direccion) {
            index = (index + direccion + imagenes.length) % imagenes.length;
            mostrarImagen();
        }

        setInterval(() => {
            cambiarImagen(1);
        }, 4000);

        mostrarImagen();
    </script>

</body>
</html>